# Pi at home
Host raspberrypi
  HostName 192.168.1.194
  User pi

### Various work machine
# HRI workstation
Host huge
  HostName huge
  User mracca

# Around
Host d005
  HostName d005
  User around

# Simulation workstation
Host siple
  HostName siple
  User mracca

Host es.naverlabs.com
  IdentityFile ~/.ssh/naverid_ed25519

Host *.int.europe.naverlabs.com
  GSSAPIDelegateCredentials yes

### Frontend Servers
Host frontend-1
  HostName 10.57.0.220
  User mracca

Host frontend-2
  HostName 10.57.0.221
  User mracca

Host sensei
  HostName 10.57.0.77
  User mracca

Host chaos-06
  HostName chaos-06.int.europe.naverlabs.com
  User mracca

### Proxy jumps for often used machines
Host siplefromhome
  HostName siple
  User mracca
  ProxyJump sensei

Host chaosfromhome
  HostName chaos-06
  User mracca
  ProxyJump sensei

Host d005fromhome
  HostName d005
  User around
  ProxyJump sensei
